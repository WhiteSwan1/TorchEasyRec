train_input_path: ""
eval_input_path: ""
model_dir: "experiments/tiger"

train_config {
    sparse_optimizer {
        adagrad_optimizer {
            lr: 0.001
        }
        constant_learning_rate {
        }
    }
    dense_optimizer {
        adam_optimizer {
            lr: 0.001
        }
        constant_learning_rate {
        }
    }
    num_epochs: 10
    save_checkpoints_steps: 1000
    log_step_count_steps: 50
}

eval_config {
    num_steps: 100
    log_step_count_steps: 10
}

data_config {
    batch_size: 64
    dataset_type: ParquetDataset
    label_fields: "label_sids"
    num_workers: 4
    fg_mode: FG_NONE
    shuffle: true
    shuffle_buffer_size: 1024
}

# History sequence of pre-SID-encoded tokens.
# sequence_length is measured in TOKENS, not items: items × num_hierarchies.
# E.g. 30 items × 3 hierarchies = 90 tokens.
feature_configs {
    sequence_id_feature {
        feature_name: "history_sids"
        # max(codebook) per Tiger.codebook = 8192; values are 0..8191.
        num_buckets: 8192
        embedding_dim: 128
        sequence_length: 90
    }
}

model_config {
    feature_groups {
        group_name: "history"
        feature_names: "history_sids"
        group_type: DEEP
    }

    tiger {
        # Backbone (matches GRID's TIGER paper defaults except for embed_dim).
        embed_dim: 128
        num_heads: 6
        d_kv: 64
        # Single-hidden-layer FF (stock T5). Use "1024,1024" for 2-hidden swap.
        hidden_dims: "1024"
        num_encoder_layers: 4
        num_decoder_layers: 4
        dropout_rate: 0.15

        # SID structure — 3-hierarchy codebook with 8192 codes per layer.
        # The training data's history_sids and label_sids columns must use
        # 0-indexed per-hierarchy codes in [0, 8192).
        codebook: "8192,8192,8192"

        # User-id branch disabled by default; set num_user_bins > 0 to enable.
        num_user_bins: 0

        # Insert a learnable SEP between each item's 3-token SID block in the
        # encoder sequence (mirrors GRID).
        use_sep_token: true

        # Beam width K during autoregressive decoding.
        beam_width: 10
    }
}
