train_input_path: ""
eval_input_path: ""
model_dir: "experiments/tiger_mock"
train_config {
    sparse_optimizer {
        adagrad_optimizer {
            lr: 0.001
        }
        constant_learning_rate {
        }
    }
    dense_optimizer {
        adam_optimizer {
            lr: 0.001
        }
        constant_learning_rate {
        }
    }
    num_epochs: 1
}
eval_config {
    num_steps: 2
}
data_config {
    batch_size: 4
    dataset_type: ParquetDataset
    label_fields: "label_sids"
    num_workers: 1
    fg_mode: FG_NONE
}
feature_configs {
    sequence_id_feature {
        feature_name: "history_sids"
        num_buckets: 256
        embedding_dim: 8
        sequence_length: 12
    }
}
model_config {
    feature_groups {
        group_name: "history"
        feature_names: "history_sids"
        group_type: DEEP
    }
    tiger {
        embed_dim: 16
        num_heads: 2
        d_kv: 8
        hidden_dims: "32"
        num_encoder_layers: 1
        num_decoder_layers: 1
        dropout_rate: 0.0
        codebook: "8,8,8"
        num_user_bins: 0
        use_sep_token: true
        beam_width: 4
    }
}
